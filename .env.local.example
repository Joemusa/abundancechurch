# Copy this to .env.local for local dev, or add to Vercel environment variables.

# Supabase — Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# Google Maps — Geocoding API key (enable Geocoding API in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Admin email — the login that sees the Admin tab and can record subscription payments.
# Set this to your own Supabase login email.
ADMIN_EMAIL=your-admin-email@example.com

# Twilio WhatsApp — from the Twilio Console home page + Messaging > Senders
# Use your sandbox credentials for testing, live credentials for production.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+27600133308
TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
